    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// FIX 1: ScraperAPI response body does not carry competitor_name/brand_name/brand_category.\n// We must pull those from the loop source node, not from the HTTP response body.\nconst body = $input.item.json;\nconst loopItem = $('Loop One by One').item.json;\n\nconst results = body.organic_results || [];\n\nconst instagramRegex = /instagram\\.com\\/([A-Za-z0-9._]{1,30})/;\nlet result_link = '';\n\nfor (const result of results) {\n  const link = result.link || result.url || '';\n  if (instagramRegex.test(link)) {\n    result_link = link;\n    break;\n  }\n}\n\nif (!result_link) {\n  const raw = JSON.stringify(body);\n  const found = raw.match(/https?:\\/\\/(?:www\\.)?instagram\\.com\\/[A-Za-z0-9._]{1,30}/);\n  if (found) result_link = found[0];\n}\n\nreturn {\n  json: {\n    competitor_name: loopItem.competitor_name,\n    brand_name: loopItem.brand_name,\n    brand_category: loopItem.brand_category,\n    serpapi_result_link: result_link\n  }\n};"
      },
      "id": "2b570b98-5160-438c-8fff-7369a8fee3ca",
      "name": "Extract Instagram Link",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -6256,
        784
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $input.item.json;\nconst link = data.serpapi_result_link || '';\n\nconst match = link.match(/instagram\\.com\\/([A-Za-z0-9._]{1,30})/);\n\nconst systemPages = ['p','explore','accounts','reel','reels','tv',\n  'stories','direct','share','about','press','legal','privacy','safety','help'];\n\nif (!match) {\n  return { json: { ...data, handle_valid: false, failure_reason: 'NO_HANDLE_EXTRACTED' } };\n}\n\nconst handle = match[1].toLowerCase();\n\nif (systemPages.includes(handle)) {\n  return { json: { ...data, handle_valid: false, failure_reason: 'SYSTEM_PAGE_URL' } };\n}\n\nif (handle.length < 2 || handle.length > 30) {\n  return { json: { ...data, handle_valid: false, failure_reason: 'INVALID_HANDLE_LENGTH' } };\n}\n\nreturn { json: { ...data, candidate_handle: handle, handle_valid: true } };"
      },
