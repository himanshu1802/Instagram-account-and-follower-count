      "id": "c09c16a6-2100-4251-8afe-be54ff7d48ac",
      "name": "Verify Live Instagram Profile",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -5600,
        672
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// FIX 2: Apify returns raw profile data with no competitor context fields.\n// Pull competitor_name/brand_name/brand_category/candidate_handle from\n// the upstream Validate Handle Format node which still carries them.\nconst upstream = $('Validate Handle Format').item.json;\nconst item = $input.item.json;\n\n// Apify sync endpoint returns an array directly — unwrap it\nlet profile = item;\nif (Array.isArray(item)) {\n  profile = item[0] || {};\n}\n\nconst username = profile.username || '';\nconst followersCount = profile.followersCount || 0;\nconst postsCount = profile.postsCount || profile.mediaCount || 0;\nconst candidateHandle = upstream.candidate_handle || '';\n\nif (!username) {\n  return { json: {\n    competitor_name: upstream.competitor_name,\n    brand_name: upstream.brand_name,\n    brand_category: upstream.brand_category,\n    candidate_handle: candidateHandle,\n    profile_valid: false,\n    failure_reason: 'PROFILE_NOT_FOUND'\n  } };\n}\n\nconst usernameMatch = username.toLowerCase() === candidateHandle.toLowerCase();\nconst hasFollowers = followersCount > 100;\nconst hasPosts = postsCount > 0;\n\nif (!usernameMatch) {\n  return { json: {\n    competitor_name: upstream.competitor_name,\n    brand_name: upstream.brand_name,\n    brand_category: upstream.brand_category,\n    candidate_handle: candidateHandle,\n    profile_valid: false,\n    failure_reason: 'USERNAME_MISMATCH'\n  } };\n}\nif (!hasFollowers) {\n  return { json: {\n    competitor_name: upstream.competitor_name,\n    brand_name: upstream.brand_name,\n    brand_category: upstream.brand_category,\n    candidate_handle: candidateHandle,\n    profile_valid: false,\n    failure_reason: 'INSUFFICIENT_FOLLOWERS'\n  } };\n}\nif (!hasPosts) {\n  return { json: {\n    competitor_name: upstream.competitor_name,\n    brand_name: upstream.brand_name,\n    brand_category: upstream.brand_category,\n    candidate_handle: candidateHandle,\n    profile_valid: false,\n    failure_reason: 'NO_POSTS'\n  } };\n}\n\nreturn { json: {\n  competitor_name: upstream.competitor_name,\n  brand_name: upstream.brand_name,\n  brand_category: upstream.brand_category,\n  candidate_handle: candidateHandle,\n  instagram_followers: followersCount,\n  instagram_bio: profile.biography || '',\n  profile_valid: true\n} };"
      },
